# Production Environment Configuration
# Copy this file to splitter/.env.production and update the URL

# Production API URL - Update with your server address
VITE_API_BASE_URL=http://yourserver.com/api

# Examples:
# For specific IP: VITE_API_BASE_URL=http://192.168.1.100/api
# For domain: VITE_API_BASE_URL=https://splitter.yourcompany.com/api
# For subdirectory: VITE_API_BASE_URL=http://yourserver.com/splitter/api

